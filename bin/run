#!/bin/bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
APP_BUNDLE="${APP_BUNDLE_DEST:-$REPO_DIR/.build/LobsMissionControl.app}"

# Resolve the executable path dynamically so this works across architectures
# and with the current binary name.
resolve_executable() {
  local candidate
  for candidate in \
    "$REPO_DIR/.build/debug/lobs-mission-control" \
    "$REPO_DIR/.build/debug/lobs-dashboard"; do
    if [ -f "$candidate" ]; then
      echo "$candidate"
      return 0
    fi
  done

  candidate="$(find "$REPO_DIR/.build" -maxdepth 4 -type f \( -name lobs-mission-control -o -name lobs-dashboard \) | head -n 1)"
  if [ -n "$candidate" ]; then
    echo "$candidate"
    return 0
  fi

  return 1
}

EXECUTABLE="$(resolve_executable || true)"

if [ -z "$EXECUTABLE" ] || [ ! -f "$EXECUTABLE" ]; then
  echo "No build found. Run bin/build first." >&2
  exit 1
fi

# Create/update a minimal .app bundle wrapping the built executable.
# Keep the bundle path stable between launches to avoid repeated TCC prompts.
mkdir -p "$APP_BUNDLE/Contents/MacOS"
mkdir -p "$APP_BUNDLE/Contents/Resources"

# Symlink the executable
rm -f "$APP_BUNDLE/Contents/MacOS/lobs-mission-control"
ln -s "$EXECUTABLE" "$APP_BUNDLE/Contents/MacOS/lobs-mission-control"

# Copy bundled resources if they exist
EXECUTABLE_DIR="$(dirname "$EXECUTABLE")"
RESOURCE_DIR="$EXECUTABLE_DIR/LobsMissionControl_LobsMissionControl.bundle"
if [ -d "$RESOURCE_DIR" ]; then
  rm -f "$APP_BUNDLE/Contents/Resources/LobsMissionControl_LobsMissionControl.bundle"
  ln -s "$RESOURCE_DIR" "$APP_BUNDLE/Contents/Resources/LobsMissionControl_LobsMissionControl.bundle"
fi

# Write Info.plist with a bundle identifier (needed for notifications, etc.)
cat > "$APP_BUNDLE/Contents/Info.plist" <<'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleIdentifier</key>
  <string>com.lobs.mission-control</string>
  <key>CFBundleName</key>
  <string>Lobs Mission Control</string>
  <key>CFBundleDisplayName</key>
  <string>Lobs Mission Control</string>
  <key>CFBundleExecutable</key>
  <string>lobs-mission-control</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>LSUIElement</key>
  <false/>
</dict>
</plist>
PLIST

# Optional dev signing.
# Default is unsigned launch to keep local privacy permissions stable.
if [ "${LOBS_CODESIGN:-0}" = "1" ]; then
  codesign --force --sign - "$APP_BUNDLE" 2>/dev/null || true
fi

open "$APP_BUNDLE"
