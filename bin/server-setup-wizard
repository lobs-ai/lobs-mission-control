#!/usr/bin/env bash
set -euo pipefail

# Lobs Server Setup Wizard
# - Installs OpenClaw (npm global)
# - Installs/starts OpenClaw Gateway service
# - Clones lobs-control + lobs-orchestrator
# - Creates Python venv + installs deps
# - Optionally installs a systemd --user service for lobs-orchestrator
#
# Usage:
#   ./server-setup-wizard
#   LOBS_CONTROL_REPO_URL=git@github.com:you/lobs-control.git ./server-setup-wizard
#   LOBS_CONTROL_DIR=~/lobs-control LOBS_ORCH_DIR=~/lobs-orchestrator ./server-setup-wizard

bold() { printf "\033[1m%s\033[0m\n" "$*"; }
info() { printf "[info] %s\n" "$*"; }
warn() { printf "[warn] %s\n" "$*"; }
err()  { printf "[err]  %s\n" "$*"; }

die() { err "$*"; exit 1; }

have() { command -v "$1" >/dev/null 2>&1; }

ask() {
  local prompt="$1"
  local default="${2:-}"
  local reply
  if [[ -n "$default" ]]; then
    read -r -p "$prompt [$default]: " reply
    echo "${reply:-$default}"
  else
    read -r -p "$prompt: " reply
    echo "$reply"
  fi
}

confirm() {
  local prompt="$1"
  local default_yes="${2:-true}"
  local suffix="[y/N]"
  if [[ "$default_yes" == "true" ]]; then
    suffix="[Y/n]"
  fi

  local reply
  read -r -p "$prompt $suffix: " reply
  reply="${reply,,}"
  if [[ -z "$reply" ]]; then
    [[ "$default_yes" == "true" ]] && return 0 || return 1
  fi
  [[ "$reply" == "y" || "$reply" == "yes" ]]
}

step() {
  local n="$1"; shift
  bold "\n== Step $n: $* =="
}

run() {
  info "$*"
  # shellcheck disable=SC2086
  eval "$*"
}

ensure_prereqs() {
  step 0 "Checking prerequisites"

  have git || die "git not found. Install git first."
  have python3 || die "python3 not found. Install Python 3.11+ first."

  if ! have node || ! have npm; then
    warn "node/npm not found. OpenClaw is distributed via npm."
    warn "Install Node.js 20+ (recommended) then re-run this wizard."
    exit 1
  fi

  info "OK: git, python3, node, npm found"
}

ensure_openclaw_installed() {
  step 1 "Installing OpenClaw (if needed)"

  if have openclaw; then
    info "OpenClaw already installed: $(openclaw --version 2>/dev/null || echo '(version unavailable)')"
    return 0
  fi

  if ! confirm "OpenClaw is not installed. Install it now with npm (requires sudo on some systems)?" true; then
    die "OpenClaw is required. Aborting."
  fi

  # Use @latest to keep setup simple.
  run "npm install -g openclaw@latest"

  have openclaw || die "OpenClaw install completed but 'openclaw' is not on PATH. See OpenClaw docs for npm global PATH fixes."
  info "Installed OpenClaw: $(openclaw --version 2>/dev/null || echo '(version unavailable)')"
}

ensure_gateway_service() {
  step 2 "Setting up OpenClaw Gateway service"

  # onboard installs the gateway supervisor (launchd/systemd) and helps configure OpenClaw.
  # It's interactive; we warn the user.
  info "Running: openclaw onboard --install-daemon"
  info "This may prompt you for configuration (providers/keys, channels, etc.)."

  run "openclaw onboard --install-daemon"

  info "Quick health checks:"
  run "openclaw doctor || true"
  run "openclaw gateway status || true"
}

clone_repo_if_missing() {
  local url="$1"
  local dest="$2"

  if [[ -d "$dest/.git" ]]; then
    info "Repo already exists: $dest"
    return 0
  fi

  mkdir -p "$(dirname "$dest")"
  run "git clone '$url' '$dest'"
}

setup_orchestrator() {
  step 3 "Cloning lobs-control + lobs-orchestrator"

  local control_url="${LOBS_CONTROL_REPO_URL:-}"
  if [[ -z "$control_url" ]]; then
    control_url="$(ask 'Enter your lobs-control git URL (SSH recommended)')"
  fi
  [[ -n "$control_url" ]] || die "lobs-control URL is required"

  local control_dir
  control_dir="${LOBS_CONTROL_DIR:-$HOME/lobs-control}"
  control_dir="${control_dir/#\~/$HOME}"

  local orch_dir
  orch_dir="${LOBS_ORCH_DIR:-$HOME/lobs-orchestrator}"
  orch_dir="${orch_dir/#\~/$HOME}"

  clone_repo_if_missing "$control_url" "$control_dir"
  clone_repo_if_missing "https://github.com/RafeSymonds/lobs-orchestrator.git" "$orch_dir"

  step 4 "Creating Python venv + installing orchestrator deps"
  if [[ ! -d "$orch_dir" ]]; then
    die "Expected orchestrator dir at $orch_dir"
  fi

  if [[ ! -d "$orch_dir/.venv" ]]; then
    run "python3 -m venv '$orch_dir/.venv'"
  fi

  # shellcheck disable=SC1091
  source "$orch_dir/.venv/bin/activate"

  run "python3 -m pip install --upgrade pip"
  if [[ -f "$orch_dir/requirements.txt" ]]; then
    run "pip install -r '$orch_dir/requirements.txt'"
  else
    warn "No requirements.txt found in $orch_dir; skipping pip install -r."
  fi

  info "Orchestrator install complete."

  step 5 "Starting orchestrator (foreground test)"
  info "We'll run it in the foreground to verify it starts. Press Ctrl+C once you see it running."
  if confirm "Start orchestrator now?" true; then
    (cd "$orch_dir" && run "python3 main.py")
  else
    info "Skipping foreground run."
  fi

  if have systemctl && systemctl --user >/dev/null 2>&1; then
    step 6 "(Optional) Install systemd --user service for lobs-orchestrator"

    if confirm "Install and enable a systemd --user service (recommended on Linux servers)?" true; then
      local unit_dir="$HOME/.config/systemd/user"
      mkdir -p "$unit_dir"

      local unit_path="$unit_dir/lobs-orchestrator.service"

      cat >"$unit_path" <<EOF
[Unit]
Description=Lobs Orchestrator
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=$orch_dir
Environment=PYTHONUNBUFFERED=1
ExecStart=$orch_dir/.venv/bin/python3 $orch_dir/main.py
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
EOF

      run "systemctl --user daemon-reload"
      run "systemctl --user enable --now lobs-orchestrator.service"
      run "systemctl --user status lobs-orchestrator.service --no-pager || true"

      info "Tip: to view logs: journalctl --user -u lobs-orchestrator -f"
    else
      info "Skipping systemd service install."
    fi
  else
    warn "systemctl --user not available; skipping service setup."
    info "You can run the orchestrator with: (cd '$orch_dir' && source .venv/bin/activate && python3 main.py)"
  fi

  bold "\nDone. Next: open your lobs-control repo locally in Lobs Dashboard and click Verify Setup."
}

main() {
  bold "Lobs Server Setup Wizard"
  info "This script will guide you through OpenClaw + orchestrator setup."

  ensure_prereqs
  ensure_openclaw_installed
  ensure_gateway_service
  setup_orchestrator
}

main "$@"
