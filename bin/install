#!/bin/bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

"$REPO_DIR/bin/build"

DEST_DIR="$HOME/Applications"
DEST_APP="$DEST_DIR/LobsDashboard.app"

mkdir -p "$DEST_DIR"

APP_BUNDLE_DEST="$DEST_APP" "$REPO_DIR/bin/run"

echo "Installed LobsDashboard to: $DEST_APP"
echo "Tip: Right-click the Dock icon → Options → Keep in Dock (so it stays when the app isn't running)."
